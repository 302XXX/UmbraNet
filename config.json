{
  "xbox_dns_mode": "dot",
  "tls_verify": true,
  "provider_failover": true,
  "fallback_dns": "8.8.8.8",
  "fallback_dns6": "2001:4860:4860::8888",
  "listen_port": 53,
  "listen_host": "127.0.0.1",
  "listen_host6": "::1",
  "enable_ipv6": true,
  "routed_cache_enabled": true,
  "routed_cache_ttl": 7,
  "routed_reply_ttl": 30,
