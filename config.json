  "optimistic_cache_enabled": true,
  "stale_cache_ttl": 86400,
  "bogus_detection_enabled": true,
  "bogus_ips_use_builtin": true,
  "bogus_ips_extra": [],
  "bogus_subnets_extra": [],
  "active_dns_profile": "builtin-xbox-dns",
  "user_dns_profiles": [],
  "routed_domains": [],
  "routed_processes": [
    "chrome.exe",
    "msedge.exe",
    "firefox.exe"
  ],
  "route_all": false,
  "ipv6_priority_enabled": false,
  "routed_subscriptions": [],
  "dpi_strategy": "uz1"
}
